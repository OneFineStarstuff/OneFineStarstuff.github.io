{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "control_mappings"],
  "properties": {
    "version": {"type": "string"},
    "control_mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["control_id", "frameworks"],
        "properties": {
          "control_id": {"type": "string", "minLength": 1},
          "frameworks": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "evidence_uri": {"type": "string"}
        }
      }
    }
  }
}
